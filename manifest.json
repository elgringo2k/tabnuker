{
  "manifest_version": 3,
  "name": "Tab Nuker",
  "version": "1.0.0",
  "description": "Close all tabs matching domains in your hit list.",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "nuke-tabs": {
      "suggested_key": {
        "mac": "Command+Shift+X",
        "windows": "Ctrl+Shift+X",
        "linux": "Ctrl+Shift+X"
      },
      "description": "Nuke all tabs in the hit list"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
