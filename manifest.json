{
  "manifest_version": 3,
  "name": "Tab Nuker",
  "version": "1.0.1",
  "description": "Nuke every open tab from your most distracting sites in one click or one keystroke. Build a hit list, stay focused.",
  "homepage_url": "https://github.com/elgringo2k/tabnuker",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "nuke-tabs": {
      "suggested_key": {
        "default": "Alt+Shift+X"
      },
      "description": "Nuke all tabs in the hit list"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
